# Dockerfile.sandbox-patch
# Extends the upstream ralph-sandbox image to add codex CLI support
# for the inner review loop.
#
# Build:
#   docker build -f docker/Dockerfile.sandbox-patch -t ralph-sandbox .
#
# The upstream image already has Node.js 20 installed, so we just
# add the codex CLI on top.

FROM ghcr.io/davesnowdon/ralph-sandbox:latest

USER root

# Install codex CLI globally
RUN npm install -g @openai/codex

# Copy our reviewed ralph script into the image
COPY scripts/ralph-reviewed.sh /usr/local/bin/ralph-reviewed.sh
RUN chmod +x /usr/local/bin/ralph-reviewed.sh

# Switch back to the non-root ralph user
USER ralph
