# ralph++ full configuration reference
#
# Config precedence (later wins):
#   1. Built-in defaults
#   2. User config:    ~/.config/ralph-plus-plus/config.yaml or ~/.ralph++.yaml
#   3. Project config: <repo>/.ralph/ralph++.yaml or <repo>/ralph++.yaml
#   4. CLI flags
#
# See examples/ for minimal user-level and project-level examples.

# ── Paths ──────────────────────────────────────────────────────────────
# repo_path: /path/to/repo         # [CLI: --repo] override with --repo flag
claude_config_dir: ~/.claude        # [user] personal tool config location
codex_config_dir: ~/.codex          # [user] personal tool config location

# ── Branch naming ──────────────────────────────────────────────────────
branch_prefix: "ralph/"             # [user/project] prefix for created branches
branch_suffix_length: 4             # [built-in] random hex chars for uniqueness

# ── PRD tool ───────────────────────────────────────────────────────────
prd_tool: claude-interactive         # [user/project] tool for PRD generation/conversion

# ── Tool definitions ───────────────────────────────────────────────────
# [user/project] If omitted, claude and codex defaults are auto-created.
tools:
  codex:
    type: cli
    command: codex
    args: ["{prompt}"]

  claude:
    type: cli
    command: claude
    args: ["--print"]
    stdin: "{prompt}"
    allowed_tools: ["Read", "Write", "Edit", "Glob", "Grep", "Bash(git:*)"]

  claude-interactive:
    type: cli
    command: claude
    args: ["{prompt}"]
    interactive: true
    allowed_tools: ["Read", "Write", "Edit", "Glob", "Grep", "Bash(git:*)"]

  # Custom tool example:
  # my_reviewer:
  #   type: shell
  #   command: "my-review-script.sh"
  #   args: ["{prompt}"]

# ── PRD review loop ────────────────────────────────────────────────────
# [user/project] Sensible defaults are built in; override here if needed.
prd_review:
  reviewer: codex
  reviewer_prompt: >
    Read the PRD at {prd_file}. Evaluate whether it is complete, unambiguous,
    and implementable as a series of independent user stories. List any flaws,
    omissions, or areas for improvement. If the PRD is fully satisfactory,
    output exactly: LGTM
  fixer: claude
  fixer_prompt: >
    The following issues were found in the PRD at {prd_file}.
    Please fix them:

    {findings}
  max_cycles: 3

# ── Post-run review loop ───────────────────────────────────────────────
# [user/project] Sensible defaults are built in; override here if needed.
post_review:
  reviewer: codex
  reviewer_prompt: >
    Read prd.json and review the entire implementation. Does the code fully
    satisfy every user story? List any flaws, omissions or areas for
    improvement. If fully satisfied, output exactly: LGTM
  fixer: claude
  fixer_prompt: >
    The following issues were found in the final implementation.
    Please fix them and ensure all tests pass:

    {findings}
  max_cycles: 3

# ── Ralph sandbox ──────────────────────────────────────────────────────
ralph:
  mode: delegated                   # [user/project/CLI: --mode] delegated | orchestrated
  max_iterations: 20                # [user/project/CLI: --max-iters]
  sandbox_dir: ../ralph-sandbox     # [user/project/CLI: --sandbox-dir] auto-resolved if omitted
  sandbox_tool: claude              # [user/project] tool for sandbox (delegated mode)
  session_runner: scripts/ralph-single-step.sh  # [user/project] orchestrated mode runner

# ── Orchestrated mode settings ─────────────────────────────────────────
# [user/project] Only used when ralph.mode is "orchestrated"
orchestrated:
  coder: claude
  reviewer: codex
  fixer: claude
  max_iteration_retries: 2
  run_tests_between_steps: false    # [project] set true + test_commands for your repo
  test_commands:                    # [project] auto-detected if empty and enabled
    - "pytest"
    - "ruff check ."
  backout_on_failure: true

  review_prompt: >
    Review the following git diff against the requirements in {prd_file}.
    Identify any flaws, omissions, regressions, or test failures.
    If everything looks correct, output exactly: LGTM

    GIT DIFF:
    {diff}

  fix_prompt: >
    The following issues were found in the latest code changes against {prd_file}.
    Please fix them and ensure all tests pass:

    {findings}

  # prompt_template: |
  #   You are implementing iteration {iteration}. The PRD is at {prd_file}.
  #   Previous review findings: {review_findings}

# ── Lifecycle hooks ────────────────────────────────────────────────────
# [user/project] Commands run at specific workflow stages.
hooks:
  post_worktree_create:
    - "codegraph init"
    - "codegraph index"
  pre_prd_generate: []
  post_prd_generate: []
  pre_sandbox: []
  post_sandbox: []
  post_complete: []
