# ralph++ full configuration reference
#
# Config precedence (later wins):
#   1. Built-in defaults
#   2. User config:    ~/.config/ralph-plus-plus/config.yaml or ~/.ralph++.yaml
#   3. Project config: <repo>/.ralph/ralph++.yaml or <repo>/ralph++.yaml
#   4. CLI flags
#
# See examples/ for minimal user-level and project-level examples.

# ── Paths ──────────────────────────────────────────────────────────────
# repo_path: /path/to/repo         # [CLI: --repo] override with --repo flag
claude_config_dir: ~/.claude        # [user] personal tool config location
codex_config_dir: ~/.codex          # [user] personal tool config location

# ── Branch naming ──────────────────────────────────────────────────────
branch_prefix: "ralph/"             # [user/project] prefix for created branches
branch_suffix_length: 4             # [built-in] random hex chars for uniqueness

# ── PRD tool ───────────────────────────────────────────────────────────
prd_tool: claude-interactive         # [user/project] tool for PRD generation/conversion
prd_json_tool: claude                # [user/project] tool for PRD-to-JSON conversion (non-interactive)

# ── Tool definitions ───────────────────────────────────────────────────
# [user/project] If omitted, claude and codex defaults are auto-created.
tools:
  codex:
    type: cli
    command: codex
    args: ["{prompt}"]

  claude:
    type: cli
    command: claude
    args: ["--print"]
    stdin: "{prompt}"
    allowed_tools: ["Read", "Write", "Edit", "Glob", "Grep", "Bash(git:*)"]

  claude-interactive:
    type: cli
    command: claude
    args: ["{prompt}"]
    interactive: true
    allowed_tools: ["Read", "Write", "Edit", "Glob", "Grep", "Bash(git:*)"]

  # Custom tool example:
  # my_reviewer:
  #   type: shell
  #   command: "my-review-script.sh"
  #   args: ["{prompt}"]

# ── PRD review loop ────────────────────────────────────────────────────
# [user/project] Sensible defaults are built in; override here if needed.
prd_review:
  reviewer: codex
  reviewer_prompt: >
    Read the PRD at {prd_file}. Evaluate whether it is complete, unambiguous,
    and implementable as a series of independent user stories. List any flaws,
    omissions, or areas for improvement. If the PRD is fully satisfactory,
    output exactly: LGTM
  fixer: claude
  fixer_prompt: >
    The following issues were found in the PRD at {prd_file}.
    Please fix them:

    {findings}
  max_cycles: 3

# ── Post-run review loop ───────────────────────────────────────────────
# [user/project] Sensible defaults are built in; override here if needed.
post_review:
  reviewer: codex
  reviewer_prompt: >
    Read prd.json and review the entire implementation. Does the code fully
    satisfy every user story? List any flaws, omissions or areas for
    improvement. If fully satisfied, output exactly: LGTM
  fixer: claude
  fixer_prompt: >
    The following issues were found in the final implementation.
    Please fix them and ensure all tests pass:

    {findings}
  max_cycles: 3

# ── Ralph sandbox ──────────────────────────────────────────────────────
ralph:
  mode: delegated                   # [user/project/CLI: --mode] delegated | orchestrated
  max_iterations: 20                # [user/project/CLI: --max-iters]
  sandbox_dir: ../ralph-sandbox     # [user/project/CLI: --sandbox-dir] auto-resolved if omitted
  sandbox_tool: claude              # [user/project] tool for sandbox (delegated mode)
  session_runner: scripts/ralph-single-step.sh  # [user/project] orchestrated mode runner

# ── Orchestrated mode settings ─────────────────────────────────────────
# [user/project] Only used when ralph.mode is "orchestrated"
orchestrated:
  coder: claude
  reviewer: codex
  fixer: claude
  max_iteration_retries: 2
  run_tests_between_steps: false    # [project] set true + test_commands for your repo
  test_commands:                    # [project] auto-detected if empty and enabled
    - "pytest"
    - "ruff check ."
  backout_on_failure: true
  max_consecutive_infra_failures: 3 # [project] abort after N coder infra failures in a row
                                    #           (OAuth expiry, network, timeout). 0 disables.
  on_retry_exhaustion: skip-story   # [project] skip-story | abort
                                    # When an iteration exhausts retries, skip the
                                    # failing story and continue instead of aborting
                                    # the whole backlog.
  # #126: detect when consecutive retries cite the same finding and stop
  # wasting cycles. Retry prompts are escalated ("REPEATED FAILURE,
  # take a fundamentally different approach") on same-finding repeats.
  max_same_finding_retries: 2        # 0 disables convergence detection
  same_finding_similarity_threshold: 0.75  # Jaccard threshold, 0.0–1.0

  review_prompt: >
    Review the following git diff against the requirements in {prd_file}.
    Identify any flaws, omissions, regressions, or test failures.
    If everything looks correct, output exactly: LGTM

    GIT DIFF:
    {diff}

  fix_prompt: >
    The following issues were found in the latest code changes against {prd_file}.
    Please fix them and ensure all tests pass:

    {findings}

  # prompt_template: |
  #   You are implementing iteration {iteration}. The PRD is at {prd_file}.
  #   Previous review findings: {review_findings}

# ── Design stance (#121) ───────────────────────────────────────────────
# [user/project] Hard constraints injected into the PRD generation prompt
# so the generator avoids scope-inappropriate architectural choices.
# Each field defaults to "unspecified" — that means no constraint is added.
design_stance:
  implementation_scope: unspecified    # unspecified | single_pass | incremental
  backward_compatibility: unspecified  # unspecified | required | not_required
  existing_tests: unspecified          # unspecified | must_pass | can_update
  api_stability: unspecified           # unspecified | extend_only | can_break
  notes: ""                             # free-form additional constraints

# ── Non-interactive defaults ───────────────────────────────────────────
# [user/project] How review gates behave when running unattended
# (no TTY, RALPH_NON_INTERACTIVE=1, --non-interactive, or enabled: true).
# on_max_cycles_* values:
#   continue   — log a warning and proceed without reviewer approval
#   abort      — raise MaxCyclesAbort and stop the workflow
#   retry-once — run one more batch of cycles, then continue
non_interactive:
  enabled: false
  on_max_cycles_prd: continue
  on_max_cycles_prd_json: continue
  on_max_cycles_post: continue

# ── Lifecycle hooks ────────────────────────────────────────────────────
# [user/project] Commands run at specific workflow stages.
hooks:
  post_worktree_create:
    - "codegraph init"
    - "codegraph index"
  pre_prd_generate: []
  post_prd_generate: []
  pre_sandbox: []
  post_sandbox: []
  post_complete: []
