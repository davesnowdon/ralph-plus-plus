# ralph++ configuration example
# Copy to ralph++.yaml and edit for your setup

# ── Paths ──────────────────────────────────────────────────────────────
# repo_path: /path/to/repo        # override with --repo flag
claude_config_dir: ~/.claude
codex_config_dir: ~/.codex

# ── Branch naming ──────────────────────────────────────────────────────
branch_prefix: "ralph/"
branch_suffix_length: 4           # random hex chars for uniqueness

# ── Tool definitions ───────────────────────────────────────────────────
tools:
  codex:
    type: cli
    command: codex
    args: ["{prompt}"]

  claude:
    type: cli
    command: claude
    args: ["--dangerously-skip-permissions", "--print"]
    stdin: "{prompt}"

  # Custom tool example:
  # my_reviewer:
  #   type: shell
  #   command: "my-review-script.sh"
  #   args: ["{prompt}"]

# ── PRD review loop ────────────────────────────────────────────────────
prd_review:
  reviewer: codex
  reviewer_prompt: >
    Read the PRD at {prd_file}. Evaluate whether it is complete, unambiguous,
    and implementable as a series of independent user stories. List any flaws,
    omissions, or areas for improvement. If the PRD is fully satisfactory,
    output exactly: LGTM
  fixer: claude
  fixer_prompt: >
    The following issues were found in the PRD at {prd_file}.
    Please fix them:

    {findings}
  max_cycles: 3

# ── Post-run review loop ───────────────────────────────────────────────
post_review:
  reviewer: codex
  reviewer_prompt: >
    Read prd.json and review the entire implementation. Does the code fully
    satisfy every user story? List any flaws, omissions or areas for
    improvement. If fully satisfied, output exactly: LGTM
  fixer: claude
  fixer_prompt: >
    The following issues were found in the final implementation.
    Please fix them and ensure all tests pass:

    {findings}
  max_cycles: 3

# ── Ralph sandbox ──────────────────────────────────────────────────────
ralph:
  mode: delegated                  # delegated | orchestrated (override with --mode)
  max_iterations: 20
  sandbox_dir: ../ralph-sandbox    # path to ralph-sandbox checkout
  sandbox_tool: claude             # tool for sandbox (delegated mode): claude | codex
  session_runner: scripts/ralph-single-step.sh  # session runner for orchestrated mode

# ── Orchestrated mode settings ─────────────────────────────────────────
# Only used when ralph.mode is "orchestrated"
orchestrated:
  coder: claude                    # tool for coding iterations (must match a key in tools section)
  reviewer: codex                  # tool for reviewing each iteration's output
  fixer: claude                    # tool for fixing review failures (used when backout_on_failure: false)
  max_iteration_retries: 2
  run_tests_between_steps: false
  test_commands:
    - "pytest"
    - "ruff check ."
  backout_on_failure: true         # true: git reset + retry iteration; false: invoke fixer to fix in-place

  # Review prompt — sent to the reviewer after each iteration.
  # Placeholders: {diff} (git diff of iteration), {prd_file} (path to prd.json)
  review_prompt: >
    Review the following git diff against the requirements in {prd_file}.
    Identify any flaws, omissions, regressions, or test failures.
    If everything looks correct, output exactly: LGTM

    GIT DIFF:
    {diff}

  # Fix prompt — sent to the fixer when review fails and backout_on_failure is false.
  # Placeholders: {findings} (reviewer output), {prd_file} (path to prd.json)
  fix_prompt: >
    The following issues were found in the latest code changes against {prd_file}.
    Please fix them and ensure all tests pass:

    {findings}

  # Optional: custom per-iteration prompt for the coder. If unset, uses upstream CLAUDE.md.
  # Placeholders: {iteration}, {prd_file}, {progress}, {review_findings}
  # prompt_template: |
  #   You are implementing iteration {iteration}. The PRD is at {prd_file}.
  #   Previous review findings: {review_findings}

# ── Lifecycle hooks ────────────────────────────────────────────────────
hooks:
  post_worktree_create:
    - "codegraph init"
    - "codegraph index"
  pre_prd_generate: []
  post_prd_generate: []
  pre_sandbox: []
  post_sandbox: []
  post_complete: []
